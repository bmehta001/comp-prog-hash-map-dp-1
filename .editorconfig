# EditorConfig -- consistent formatting across all editors
# https://editorconfig.org
#
# Supported by: VS Code, IntelliJ, Eclipse, Visual Studio, NetBeans, CLion,
# PyCharm, BlueJ (via plugin), and most modern editors.

root = true

# ── Defaults for all files ────────────────────────────────
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# ── Java ──────────────────────────────────────────────────
[*.java]
indent_size = 4
max_line_length = 120

# ── Python ────────────────────────────────────────────────
[*.py]
indent_size = 4
max_line_length = 120

# ── C++ ───────────────────────────────────────────────────
[*.{cpp,h,hpp}]
indent_size = 4
max_line_length = 120

# ── Markdown ──────────────────────────────────────────────
[*.md]
trim_trailing_whitespace = false
max_line_length = off

# ── YAML / JSON ──────────────────────────────────────────
[*.{yml,yaml,json}]
indent_size = 2
